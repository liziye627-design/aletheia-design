# ============================================
# Aletheia Backend - 环境变量配置
# ============================================

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://user:password@localhost:5432/aletheia

# ==================== API配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ==================== LLM配置 (核心功能) ====================

# SiliconFlow（统一入口）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_SMALL_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_LARGE_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct
SILICONFLOW_ALLOW_WEB_SEARCH_FALLBACK=true
SOURCE_PLANNER_MODE=precision    # 选源模式: precision/balanced
INVESTIGATION_MIN_VALID_EVIDENCE_HARD_FLOOR=100
INVESTIGATION_CLAIM_REASONING_TIMEOUT_SEC=15
INVESTIGATION_CLAIM_MIN_RELEVANCE=0.2
INVESTIGATION_PREVIEW_TTL_MINUTES=30
INVESTIGATION_PREVIEW_LLM_TIMEOUT_SEC=4
INVESTIGATION_PREVIEW_MAX_CLAIMS=6
INVESTIGATION_PREVIEW_SUMMARY_TARGET_CHARS=200
INVESTIGATION_PREVIEW_SUMMARY_MIN_CHARS=160
INVESTIGATION_PREVIEW_SUMMARY_MAX_CHARS=260
INVESTIGATION_ENABLE_OPINION_MONITORING=True
INVESTIGATION_OPINION_COMMENT_TARGET=120
INVESTIGATION_OPINION_COMMENT_LIMIT_PER_POST=40
INVESTIGATION_OPINION_MAX_POSTS_PER_PLATFORM=2
INVESTIGATION_OPINION_MAX_PLATFORMS=6
INVESTIGATION_OPINION_ALLOW_SYNTHETIC_COMMENTS=False
INVESTIGATION_OPINION_GAP_FORCE_REVIEW=False
INVESTIGATION_OPINION_SUSPICIOUS_RATIO_MEDIUM=0.25
INVESTIGATION_OPINION_SUSPICIOUS_RATIO_HIGH=0.45
INVESTIGATION_STRICT_MUST_HAVE_GATING=False
INVESTIGATION_CACHED_EVIDENCE_MIN_RELEVANCE=0.22
INVESTIGATION_RELEVANCE_THRESHOLD_STRICT=0.30
INVESTIGATION_RELEVANCE_THRESHOLD_BALANCED=0.22
INVESTIGATION_RELEVANCE_FLOOR=0.22
INVESTIGATION_EXTERNAL_EVIDENCE_MIN_RELEVANCE=0.30
INVESTIGATION_ALLOW_LOW_RELEVANCE_RESCUE=false
INVESTIGATION_EVIDENCE_ORDER_MODE=relevance_desc
INVESTIGATION_ENABLE_EXTERNAL_SOURCES=true
INVESTIGATION_EXTERNAL_TIMEOUT_SEC=20
INVESTIGATION_EXTERNAL_SEARCH_ENABLED=true
INVESTIGATION_EXTERNAL_SEARCH_MODE=always
INVESTIGATION_EXTERNAL_SEARCH_PROVIDER=google_news_rss
INVESTIGATION_EXTERNAL_SEARCH_PROVIDER_CHAIN=google_news_rss
INVESTIGATION_EXTERNAL_SEARCH_TRIGGER_MIN_EVIDENCE=120
INVESTIGATION_EXTERNAL_SEARCH_TRIGGER_MIN_PLATFORMS=4
INVESTIGATION_EXTERNAL_SEARCH_MAX_RESULTS=20
INVESTIGATION_EXTERNAL_SEARCH_PER_PROVIDER_LIMIT=20
INVESTIGATION_EXTERNAL_SEARCH_TIMEOUT_SEC=6
INVESTIGATION_EXTERNAL_SEARCH_MIN_RELEVANCE=0.30
INVESTIGATION_EXTERNAL_SEARCH_REQUIRE_ENTITY_HIT=true
INVESTIGATION_EXTERNAL_SEARCH_REQUIRE_EVENT_HINT_HIT=false
INVESTIGATION_EXTERNAL_SEARCH_WHITELIST_ONLY=true
INVESTIGATION_EXTERNAL_SEARCH_ALLOWED_DOMAINS=news.cn,people.com.cn,chinanews.com.cn,cctv.com,china.com.cn,gov.cn,xinhuanet.com,thepaper.cn,caixin.com,36kr.com,jiemian.com,samr.gov.cn,csrc.gov.cn,nhc.gov.cn,mps.gov.cn,mem.gov.cn
INVESTIGATION_EXTERNAL_SEARCH_MAX_DOMAIN_QUERIES=8
INVESTIGATION_EXTERNAL_SEARCH_CONCURRENCY=4
INVESTIGATION_EXTERNAL_SEARCH_MAX_TOTAL_RESULTS=200
INVESTIGATION_EXTERNAL_SEARCH_SEARXNG_BASE_URL=
INVESTIGATION_EXTERNAL_SEARCH_SEARXNG_TIMEOUT_SEC=6
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_BASE_URL=https://api.bocha.cn/v1
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_API_KEY=
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_TIMEOUT_SEC=8
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_MAX_RESULTS=50
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_SUMMARY=true
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_FRESHNESS=noLimit
INVESTIGATION_EXTERNAL_SEARCH_BOCHA_ENABLE_SITE_SCOPED_QUERIES=false

# 出口网络模式（本地开发建议固定代理）
OUTBOUND_NETWORK_MODE=fixed_proxy
OUTBOUND_PROXY_URL=http://127.0.0.1:7897
OUTBOUND_NO_PROXY=127.0.0.1,localhost,::1

# Search 发现源配置（SearchHit Discovery）
SEARCH_SOURCES_CONFIG_ENABLED=true
SEARCH_SOURCES_CONFIG_PATH=config/search_sources.yaml
SEARCH_SOURCES_CONFIG_EXTRA_PATHS=
SEARCH_SOURCES_CONFIG_REFRESH_SEC=5
SEARCH_SOURCES_REQUIRE_CN_FOR_ZH_QUERY=true
CRAWLER_SEARCH_MAX_CONCURRENCY=8
CRAWLER_BOCHA_FALLBACK_ENABLED=true
CRAWLER_BOCHA_FALLBACK_PLATFORM_ALLOWLIST=rss_pool,news,weibo,zhihu,xinhua,peoples_daily
CRAWLER_BOCHA_FALLBACK_MAX_QUERY_VARIANTS=1
CRAWLER_BOCHA_FALLBACK_FETCH_MULTIPLIER=2
CRAWLER_BOCHA_FALLBACK_CACHE_TTL_SEC=120
CRAWLER_BOCHA_FALLBACK_ALLOW_CROSS_DOMAIN_FOR_SOCIAL=true
CRAWLER_BOCHA_FALLBACK_SOCIAL_PLATFORMS=weibo,zhihu,xiaohongshu,douyin,bilibili,kuaishou,douban

# LLM功能开关
ENABLE_SENTIMENT_ANALYSIS=true     # 情感分析
ENABLE_FACT_CHECKING=true          # 事实核查
ENABLE_REPORT_GENERATION=true      # 报告生成
ENABLE_CONTENT_SUMMARIZATION=true  # 内容摘要

# ==================== 社交媒体爬虫配置 ====================

# 小红书爬虫配置(可选 - Agent系统不需要)
XHS_COOKIES=

# 抖音爬虫配置(可选 - Agent系统不需要)
DOUYIN_COOKIES=

# 知乎爬虫配置(推荐 - 提升Crawler质量)
ZHIHU_COOKIES=
ZHIHU_COOKIES_POOL=

# B站爬虫配置(可选 - Agent系统不需要)
BILIBILI_COOKIES=

# 快手爬虫配置(可选)
KUAISHOU_COOKIES=

# 豆瓣爬虫配置(可选)
DOUBAN_COOKIES=

# 微博爬虫配置(可选)
WEIBO_COOKIES=
WEIBO_COOKIES_POOL=
WEIBO_ENABLE_PUBLIC_SEARCH=true
WEIBO_SEARCH_ALLOW_HOT_FALLBACK=false

# 账号池（微博/知乎）可用；多个 Cookie 用逗号/换行分隔
ACCOUNT_POOL_ENABLED=true
ACCOUNT_POOL_MAX_FAILURES=3
ACCOUNT_POOL_COOLDOWN_SEC=300

# ==================== 国际平台API配置 ====================

# YouTube配置
YOUTUBE_API_KEY=

# Reddit配置
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Aletheia/1.0 (by /u/aletheia_bot)

# Twitter/X API配置
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# GitHub / Stack Overflow
GITHUB_TOKEN=
STACKOVERFLOW_API_KEY=

# Facebook/Meta Graph API配置(可选)
META_APP_ID=
META_APP_SECRET=

# ==================== 官方来源配置 ====================
# (通常无需凭证,使用公开RSS/Web)
# 如需特定API,在此配置

# 新华社API (如有)
XINHUA_API_KEY=

# 人民日报API (如有)
PEOPLES_DAILY_API_KEY=

# ==================== 新闻媒体付费源 ====================

# Reuters API
REUTERS_API_KEY=

# Factiva (道琼斯新闻数据库)
FACTIVA_API_KEY=

# Bloomberg Terminal
BLOOMBERG_API_KEY=

# ==================== 学术数据集 ====================

# OpenAlex (免费,有Key可提升限额)
OPENALEX_API_KEY=
OPENALEX_EMAIL=your_email@example.com

# GDELT (免费,无需Key)
# Common Crawl (免费,无需Key)

# ==================== 数据供应商 ====================

# Event Registry
EVENTREGISTRY_API_KEY=

# Meltwater (媒体监控)
MELTWATER_API_KEY=

# Brandwatch (社交聆听)
BRANDWATCH_API_KEY=

# ==================== Playwright配置 ====================

# 浏览器类型 (chromium/firefox/webkit)
PLAYWRIGHT_BROWSER=chromium

# 无头模式 (true/false)
PLAYWRIGHT_HEADLESS=true

# 浏览器超时时间(毫秒)
PLAYWRIGHT_TIMEOUT=30000

# 最大并发浏览器实例
MAX_CONCURRENT_BROWSERS=5

# 关键词匹配阈值（检索阶段 token overlap）
CRAWLER_KEYWORD_MATCH_THRESHOLD=0.2
# 搜索模式禁用热榜兜底（建议开启，避免无关内容污染证据）
CRAWLER_DISABLE_HOT_FALLBACK_IN_SEARCH=true
# 无精确命中时每平台热点兜底上限（社交平台默认较低，避免噪声）
CRAWLER_HOT_FALLBACK_MAX_ITEMS=5
# 高可信平台（官方/权威媒体）热点兜底上限，保障证据池覆盖
CRAWLER_HOT_FALLBACK_MAX_ITEMS_TRUSTED=20

# RSS 聚合源本地索引回看窗口（天）
RSS_POOL_LOCAL_INDEX_LOOKBACK_DAYS=180

# 官方源（无站内搜索）策略：列表/RSS增量 + 本地索引检索
OFFICIAL_SOURCE_SEARCH_LOCAL_FIRST=true
OFFICIAL_SOURCE_SEARCH_LOCAL_MIN_RESULTS=2
OFFICIAL_SOURCE_SEARCH_LOCAL_LOOKBACK_DAYS=180
OFFICIAL_SOURCE_SEARCH_FETCH_MULTIPLIER=8
OFFICIAL_SOURCE_SEARCH_FETCH_MIN_LIMIT=60
OFFICIAL_SOURCE_SEARCH_INDEX_WRITE_ENABLED=true
OFFICIAL_SOURCE_SEARCH_INDEX_WRITE_MAX_ITEMS=120

# ==================== MediaCrawler Sidecar (非商业学习用途) ====================
# 仅当以下两项同时为 true 时，Aletheia 才会启用 sidecar 增强
MEDIACRAWLER_ENABLED=true
MEDIACRAWLER_NONCOMMERCIAL_ACK=true

MEDIACRAWLER_BASE_URL=http://127.0.0.1:18080
MEDIACRAWLER_AUTO_START=true
MEDIACRAWLER_HOME=third_party/MediaCrawler
MEDIACRAWLER_START_COMMAND=uv run uvicorn api.main:app --host 127.0.0.1 --port 18080
MEDIACRAWLER_HEADLESS=false
MEDIACRAWLER_STARTUP_TIMEOUT_SEC=45
MEDIACRAWLER_REQUEST_TIMEOUT_SEC=15
MEDIACRAWLER_TASK_TIMEOUT_SEC=120
MEDIACRAWLER_PLATFORMS=xiaohongshu,douyin,weibo,zhihu
MEDIACRAWLER_MAX_ITEMS_PER_PLATFORM=80
MEDIACRAWLER_TRIGGER_EMPTY_ONLY=false
MEDIACRAWLER_TRIGGER_ALL_FALLBACK=true

# ==================== Redis配置 (缓存) ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 缓存过期时间(秒)
CACHE_TTL=3600

# ==================== 日志配置 ====================

LOG_LEVEL=INFO  # DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_FORMAT=json  # json/text
LOG_FILE=logs/aletheia.log

# ==================== CORS配置 ====================

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# ==================== 数据准确度验证配置 ====================

# 最小证据数量 (少于此数量视为证据不足)
MIN_EVIDENCE_COUNT=5

# 最小置信度阈值 (低于此阈值发出警告)
MIN_CONFIDENCE_THRESHOLD=0.7

# Agent一致性要求 (至少多少比例的Agent达成共识)
MIN_AGENT_CONSENSUS=0.75

# 启用多源交叉验证
ENABLE_CROSS_VERIFICATION=true

# ==================== 情感分析配置 ====================

# 情感分析模型
SENTIMENT_MODEL=kimi  # kimi/stepfun/openai

# 情感分析细粒度 (3-class: 正/中/负, 5-class: 很正/正/中/负/很负)
SENTIMENT_GRANULARITY=5

# 批量分析大小
SENTIMENT_BATCH_SIZE=20

# ==================== 报告生成配置 ====================

# 报告生成LLM
REPORT_GENERATOR_MODEL=kimi

# 报告语言
REPORT_LANGUAGE=zh-CN  # zh-CN/en-US

# 报告详细程度 (brief/standard/detailed)
REPORT_DETAIL_LEVEL=detailed

# 启用可视化图表
ENABLE_REPORT_VISUALIZATION=true

# ==================== 性能监控 ====================

# 启用性能追踪
ENABLE_PERFORMANCE_TRACKING=true

# 启用错误上报
ENABLE_ERROR_REPORTING=true

# Sentry DSN (可选)
SENTRY_DSN=

# ==================== 开发模式 ====================

# 开发模式 (true/false)
DEBUG_MODE=false

# 保存原始数据用于调试
SAVE_RAW_DATA=false

# 跳过LLM调用(测试用)
SKIP_LLM_CALLS=false
