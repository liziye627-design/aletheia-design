# ======================
# 应用配置
# ======================
APP_NAME=Aletheia
APP_VERSION=1.0.0
DEBUG=False

# ======================
# 安全配置
# ======================
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters-long

# ======================
# 数据库配置
# ======================
POSTGRES_SERVER=localhost
POSTGRES_USER=aletheia
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=aletheia

# ======================
# Redis配置
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# ======================
# Kafka配置
# ======================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ======================
# SiliconFlow配置
# ======================
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_SMALL_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_LARGE_MODEL=deepseek-ai/DeepSeek-V3

# ======================
# 爬虫配置(可选)
# ======================
WEIBO_COOKIES=
TWITTER_BEARER_TOKEN=
XHS_COOKIES=
DOUYIN_COOKIES=

# ======================
# Google Maps API(可选)
# ======================
GOOGLE_MAPS_API_KEY=

# ======================
# 监控配置(可选)
# ======================
SENTRY_DSN=
PROMETHEUS_ENABLED=True

# ======================
# 日志配置
# ======================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ======================
# CORS配置
# ======================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
